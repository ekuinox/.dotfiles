{{- if ne .chezmoi.os "windows" -}}
#!/usr/bin/env bash
# chezmoi apply の run_onchange フック。
# Figma リモート MCP サーバー（https://mcp.figma.com/mcp）を user スコープで冪等登録する。
# 認証はブラウザ OAuth。登録後に `claude` を起動して `/mcp` -> figma -> Authenticate を実行する。
set -euo pipefail

if ! command -v claude >/dev/null 2>&1; then
  echo "claude not found; skip figma MCP registration"
  exit 0
fi

if claude mcp get figma >/dev/null 2>&1; then
  echo "skip (already registered): figma"
  exit 0
fi

echo "registering figma MCP (remote, user scope)"
claude mcp add --scope user --transport http figma https://mcp.figma.com/mcp
echo "done. authenticate via: claude -> /mcp -> figma -> Authenticate"
{{- end -}}
